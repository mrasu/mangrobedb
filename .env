RUST_LOG=mangrobe_db=debug
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
AWS_REGION=us-east-1
AWS_ALLOW_HTTP=true

# MANGROBE_DB settings can be configured via config files or environment variables.
# When using environment variables, prefix keys with MANGROBE_DB.
# Example:
# MANGROBE_DB_S3__BUCKET=mangrobe-db-development
